generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPERADMIN
  BANK_ADMIN
  BANK_OPS
  BANK_APPROVER
  BANK_BRANCH_MANAGER
  BANK_BRANCH_OPERATOR
  BRAND_ADMIN
  LEGAL_ENTITY_ADMIN
  POS_ADMIN
  MERCHANT_ADMIN
  MERCHANT_USER
  ADMIN
  MERCHANT
  OPERATIONS
}

enum MerchantStatus {
  ACTIVE
  PENDING
  RESTRICTED
}

enum CardNetwork {
  VISA
  MASTERCARD
  AMEX
  CABAL
  NARANJA
  OTRA
}

enum CampaignStatus {
  EDITING
  PENDING
  ACTIVE
  FINALIZED
  CANCELLED
  ARCHIVED
}

enum CampaignBenefitType {
  DISCOUNT
  INSTALLMENTS
  INSTALLMENTS_DISCOUNT
  CASHBACK
  FINANCING
  BANK_CREDENTIAL
}

enum CampaignCommercialStatus {
  INVITACION
  OPERACIONES
  ADMINISTRADORA
  PARCIAL
  OK
}

enum CampaignAdhesionStatus {
  PENDIENTE
  ACEPTADA
  RECHAZADA
}

enum CampaignTargetMode {
  RETAILER_PDV
  RUBROS
  SHOPPING
  LOCATION
}

enum CampaignLocationLevel {
  COUNTRY
  PROVINCE
  CITY
}

enum CampaignCloseType {
  WITH_CLOSE_DATE
  WITHOUT_CLOSE_DATE
}

enum InvitationStatus {
  INVITED
  ACCEPTED
  REJECTED
  EXPIRED
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
}

enum NotificationType {
  INVITATION
  REMINDER
  VALIDATION_ERROR
  WELCOME
  PASSWORD_RESET
  TWO_FACTOR_CODE
}

enum ProvisioningTarget {
  VPS_MANAGED
  CUSTOMER_CLOUD
  ON_PREM
}

enum ProvisioningStatus {
  REQUESTED
  RUNNING
  READY
  FAILED
  CANCELLED
}

model Bank {
  id                  String    @id @default(cuid())
  nombre              String
  nombreCompleto      String?
  razonSocial         String?
  cuit                String?
  direccionCasaMatriz String?
  slug                String    @unique
  logoUrl             String?
  paymentMethods      String[]
  bines               String[]
  timezone            String    @default("America/Argentina/Buenos_Aires")
  fechaAlta           DateTime?
  activo              Boolean   @default(true)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  users                User[]
  brands               Brand[]
  bankBranches         BankBranch[]
  merchants            Merchant[]
  branches             Branch[]
  categories           Category[]
  brandCategories      BrandCategory[]
  shoppings            Shopping[]
  branchEstablishments BranchEstablishment[]
  cardCodeConfigs      BankCardCodeConfig[]
  processorConfigs     BankProcessorConfig[]
  campaignTypeConfigs  BankCampaignTypeConfig[]
  binConfigs           BankBinConfig[]
  campaigns            Campaign[]
  generatedCampaignForms CampaignGeneratedForm[]
  invitations          Invitation[]
  validations          ValidationError[]
  notifications        Notification[]
  auditLogs            AuditLog[]
  provisioningRequests BankProvisioningRequest[]
}

model BankBranch {
  id        String   @id @default(cuid())
  bankId    String
  bank      Bank     @relation(fields: [bankId], references: [id])
  nombre    String
  codigo    String?
  localidad String?
  region    String?
  tipo      String?
  direccion String?
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users User[]

  @@index([bankId])
}

model User {
  id                    String    @id @default(cuid())
  tenantId              String
  bank                  Bank      @relation(fields: [tenantId], references: [id])
  email                 String
  passwordHash          String
  nombre                String
  role                  Role
  brandId               String?
  merchantId            String?
  bankBranchId          String?
  pointOfSaleId         String?
  isActive              Boolean   @default(true)
  twoFactorEmailEnabled Boolean   @default(false)
  twoFactorTotpEnabled  Boolean   @default(false)
  twoFactorTotpSecret   String?
  lastLoginAt           DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  brand               Brand?               @relation(fields: [brandId], references: [id])
  merchant            Merchant?            @relation(fields: [merchantId], references: [id])
  bankBranch          BankBranch?          @relation(fields: [bankBranchId], references: [id])
  pointOfSale         Branch?              @relation("UserPointOfSale", fields: [pointOfSaleId], references: [id])
  auditLogs           AuditLog[]
  archivedCampaigns   Campaign[]           @relation("CampaignArchivedBy")
  passwordResetTokens PasswordResetToken[]
  twoFactorSessions   TwoFactorSession[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([bankBranchId])
  @@index([brandId])
  @@index([merchantId])
  @@index([pointOfSaleId])
}

model Brand {
  id                String   @id @default(cuid())
  tenantId          String
  bank              Bank     @relation(fields: [tenantId], references: [id])
  nombre            String
  logoUrl           String?
  sitioWeb          String?
  facebook          String?
  instagram         String?
  twitter           String?
  emailPrincipal    String?
  telefonoPrincipal String?
  processor         String?
  activo            Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  legalEntities   BrandLegalEntity[]
  categories      BrandCategory[]
  branches        Branch[]
  campaignTargets CampaignTargetRetailer[]
  users           User[]

  @@index([tenantId])
}

model BrandLegalEntity {
  id         String   @id @default(cuid())
  tenantId   String
  brandId    String
  merchantId String
  createdAt  DateTime @default(now())

  brand    Brand    @relation(fields: [brandId], references: [id])
  merchant Merchant @relation(fields: [merchantId], references: [id])

  @@unique([brandId, merchantId])
  @@index([tenantId])
  @@index([brandId])
  @@index([merchantId])
}

model Category {
  id        String   @id @default(cuid())
  tenantId  String
  bank      Bank     @relation(fields: [tenantId], references: [id])
  nombre    String
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  brands          BrandCategory[]
  campaignTargets CampaignTargetCategory[]

  @@unique([tenantId, nombre])
  @@index([tenantId])
}

model BrandCategory {
  id         String   @id @default(cuid())
  tenantId   String
  brandId    String
  categoryId String
  createdAt  DateTime @default(now())

  bank     Bank     @relation(fields: [tenantId], references: [id])
  brand    Brand    @relation(fields: [brandId], references: [id])
  category Category @relation(fields: [categoryId], references: [id])

  @@unique([brandId, categoryId])
  @@index([tenantId])
  @@index([brandId])
  @@index([categoryId])
}

model Merchant {
  id              String         @id @default(cuid())
  tenantId        String
  bank            Bank           @relation(fields: [tenantId], references: [id])
  nombre          String
  razonSocial     String?
  categoria       String
  estado          MerchantStatus @default(PENDING)
  cuit            String?
  direccionSocial String?
  merchantNumber  String?
  contactoEmail   String?
  telefono        String?
  processor       String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  branches    Branch[]
  brands      BrandLegalEntity[]
  invitations Invitation[]
  validations ValidationError[]
  users       User[]
  campaignAdhesions CampaignMerchantAdhesion[]
  generatedCampaignForms CampaignGeneratedForm[]

  @@index([tenantId])
}

model Branch {
  id             String    @id @default(cuid())
  tenantId       String
  bank           Bank      @relation(fields: [tenantId], references: [id])
  merchantId     String
  merchant       Merchant  @relation(fields: [merchantId], references: [id])
  retailerId     String?
  retailer       Brand?    @relation(fields: [retailerId], references: [id])
  nombre         String
  direccion      String
  calle          String?
  numero         String?
  piso           String?
  codigoPostal   String?
  ciudad         String
  provincia      String
  pais           String
  placeId        String?
  lat            Float?
  lng            Float?
  merchantNumber String?
  processor      String?
  activo         Boolean   @default(true)
  shoppingId     String?
  shopping       Shopping? @relation(fields: [shoppingId], references: [id])
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  users           User[]                 @relation("UserPointOfSale")
  establishments  BranchEstablishment[]
  campaignTargets CampaignTargetBranch[]
  invitationLinks InvitationBranch[]

  @@index([tenantId])
  @@index([tenantId, activo])
  @@index([merchantId])
  @@index([retailerId])
  @@index([shoppingId])
}

model Shopping {
  id        String   @id @default(cuid())
  tenantId  String
  bank      Bank     @relation(fields: [tenantId], references: [id])
  nombre    String
  grupo     String?
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  branches        Branch[]
  campaignTargets CampaignTargetShopping[]

  @@unique([tenantId, nombre])
  @@index([tenantId])
  @@index([tenantId, grupo])
}

model BranchEstablishment {
  id          String      @id @default(cuid())
  tenantId    String
  bank        Bank        @relation(fields: [tenantId], references: [id])
  branchId    String
  branch      Branch      @relation(fields: [branchId], references: [id])
  cardNetwork CardNetwork
  number      String
  createdAt   DateTime    @default(now())

  @@unique([branchId, cardNetwork])
  @@index([tenantId])
  @@index([branchId])
}

model BankCardCodeConfig {
  id        String      @id @default(cuid())
  tenantId  String
  bank      Bank        @relation(fields: [tenantId], references: [id])
  network   CardNetwork
  label     String
  active    Boolean     @default(true)
  sortOrder Int         @default(0)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  campaignLinks CampaignPaymentMethod[]

  @@unique([tenantId, network])
  @@index([tenantId])
  @@index([tenantId, active])
}

model BankProcessorConfig {
  id        String   @id @default(cuid())
  tenantId  String
  bank      Bank     @relation(fields: [tenantId], references: [id])
  nombre    String
  active    Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, nombre])
  @@index([tenantId])
  @@index([tenantId, active])
}

model BankCampaignTypeConfig {
  id        String             @id @default(cuid())
  tenantId  String
  bank      Bank               @relation(fields: [tenantId], references: [id])
  nombre    String
  benefitType CampaignBenefitType @default(DISCOUNT)
  mode      CampaignTargetMode
  locked    Boolean            @default(false)
  active    Boolean            @default(true)
  sortOrder Int                @default(0)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  campaigns Campaign[]

  @@unique([tenantId, nombre])
  @@index([tenantId])
  @@index([tenantId, active])
  @@index([tenantId, benefitType])
  @@index([tenantId, mode])
}

model Campaign {
  id                   String                 @id @default(cuid())
  tenantId             String
  bank                 Bank                   @relation(fields: [tenantId], references: [id])
  nombre               String
  campaignTypeConfigId String
  campaignTypeConfig   BankCampaignTypeConfig @relation(fields: [campaignTypeConfigId], references: [id])
  closeType            CampaignCloseType
  estado               CampaignStatus         @default(EDITING)
  commercialStatus     CampaignCommercialStatus @default(INVITACION)
  estadoAnterior       CampaignStatus?
  archivedAt           DateTime?
  archivedById         String?
  archivedBy           User?                  @relation("CampaignArchivedBy", fields: [archivedById], references: [id])
  codigoInterno        String?
  codigoExterno        String?
  fechaVigDesde        DateTime
  fechaVigHasta        DateTime
  fechaCierre          DateTime?
  dias                 String[]
  targetAllShoppings   Boolean                @default(false)
  locationLevel        CampaignLocationLevel?
  fechaPrioridad       DateTime?
  condiciones          Json?
  eligibility          Json?
  resolvedBines        String[]               @default([])
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt

  targetRetailers  CampaignTargetRetailer[]
  targetBranches   CampaignTargetBranch[]
  targetCategories CampaignTargetCategory[]
  targetShoppings  CampaignTargetShopping[]
  targetLocations  CampaignTargetLocation[]
  paymentMethods   CampaignPaymentMethod[]
  processorCodes   CampaignProcessorCode[]
  merchantAdhesions CampaignMerchantAdhesion[]
  generatedForms   CampaignGeneratedForm[]

  @@index([tenantId])
  @@index([tenantId, estado])
  @@index([tenantId, commercialStatus])
  @@index([tenantId, fechaVigHasta])
  @@index([tenantId, locationLevel])
  @@index([campaignTypeConfigId])
  @@index([archivedById])
  @@unique([tenantId, codigoInterno])
}

model CampaignTargetRetailer {
  id         String   @id @default(cuid())
  tenantId   String
  campaignId String
  retailerId String
  createdAt  DateTime @default(now())

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  retailer Brand    @relation(fields: [retailerId], references: [id], onDelete: Cascade)

  @@unique([campaignId, retailerId])
  @@index([tenantId])
  @@index([campaignId])
  @@index([retailerId])
}

model CampaignTargetBranch {
  id         String   @id @default(cuid())
  tenantId   String
  campaignId String
  branchId   String
  createdAt  DateTime @default(now())

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  branch   Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([campaignId, branchId])
  @@index([tenantId])
  @@index([campaignId])
  @@index([branchId])
}

model CampaignTargetCategory {
  id         String   @id @default(cuid())
  tenantId   String
  campaignId String
  categoryId String
  createdAt  DateTime @default(now())

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([campaignId, categoryId])
  @@index([tenantId])
  @@index([campaignId])
  @@index([categoryId])
}

model CampaignTargetShopping {
  id         String   @id @default(cuid())
  tenantId   String
  campaignId String
  shoppingId String
  createdAt  DateTime @default(now())

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  shopping Shopping @relation(fields: [shoppingId], references: [id], onDelete: Cascade)

  @@unique([campaignId, shoppingId])
  @@index([tenantId])
  @@index([campaignId])
  @@index([shoppingId])
}

model CampaignTargetLocation {
  id         String                @id @default(cuid())
  tenantId   String
  campaignId String
  level      CampaignLocationLevel
  value      String
  createdAt  DateTime              @default(now())

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, level, value])
  @@index([tenantId])
  @@index([campaignId])
  @@index([level])
}

model CampaignPaymentMethod {
  id               String   @id @default(cuid())
  tenantId         String
  campaignId       String
  cardCodeConfigId String
  createdAt        DateTime @default(now())

  campaign       Campaign           @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  cardCodeConfig BankCardCodeConfig @relation(fields: [cardCodeConfigId], references: [id], onDelete: Cascade)

  @@unique([campaignId, cardCodeConfigId])
  @@index([tenantId])
  @@index([campaignId])
  @@index([cardCodeConfigId])
}

model CampaignProcessorCode {
  id         String   @id @default(cuid())
  tenantId   String
  campaignId String
  processor  String
  code       String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, processor, code])
  @@index([tenantId])
  @@index([campaignId])
}

model CampaignMerchantAdhesion {
  id         String                @id @default(cuid())
  tenantId   String
  campaignId String
  merchantId String
  status     CampaignAdhesionStatus @default(PENDIENTE)
  respondedAt DateTime?
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  merchant Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@unique([campaignId, merchantId])
  @@index([tenantId])
  @@index([campaignId])
  @@index([merchantId])
  @@index([tenantId, status])
}

model CampaignGeneratedForm {
  id           String   @id @default(cuid())
  tenantId     String
  campaignId   String
  merchantId   String
  invitationId String?
  processor    String
  campaignType String
  formTemplate String
  mainForm     Json
  binsSheet    Json
  merchantsSheet Json
  financingSheet Json
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  bank       Bank       @relation(fields: [tenantId], references: [id])
  campaign   Campaign   @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  merchant   Merchant   @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  invitation Invitation? @relation(fields: [invitationId], references: [id], onDelete: SetNull)

  @@unique([campaignId, merchantId, processor, formTemplate])
  @@index([tenantId])
  @@index([campaignId])
  @@index([merchantId])
  @@index([invitationId])
  @@index([tenantId, processor])
}

model BankBinConfig {
  id        String   @id @default(cuid())
  tenantId  String
  bank      Bank     @relation(fields: [tenantId], references: [id])
  bin       String
  network   String
  cardType  String
  segment   String?
  alliance  String?
  channel   String?
  product   String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, bin])
  @@index([tenantId])
  @@index([tenantId, active])
  @@index([tenantId, network])
  @@index([tenantId, cardType])
  @@index([tenantId, segment])
  @@index([tenantId, alliance])
}

model Invitation {
  id         String           @id @default(cuid())
  tenantId   String
  bank       Bank             @relation(fields: [tenantId], references: [id])
  email      String
  merchantId String?
  merchant   Merchant?        @relation(fields: [merchantId], references: [id])
  status     InvitationStatus @default(INVITED)
  token      String           @unique
  expiresAt  DateTime?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  branches InvitationBranch[]
  generatedCampaignForms CampaignGeneratedForm[]

  @@index([tenantId])
}

model InvitationBranch {
  id           String @id @default(cuid())
  tenantId     String
  invitationId String
  branchId     String

  invitation Invitation @relation(fields: [invitationId], references: [id])
  branch     Branch     @relation(fields: [branchId], references: [id])

  @@index([tenantId])
}

model ValidationError {
  id         String   @id @default(cuid())
  tenantId   String
  bank       Bank     @relation(fields: [tenantId], references: [id])
  merchantId String
  merchant   Merchant @relation(fields: [merchantId], references: [id])
  codigo     String
  mensaje    String
  resuelto   Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([tenantId])
}

model Notification {
  id        String           @id @default(cuid())
  tenantId  String
  bank      Bank             @relation(fields: [tenantId], references: [id])
  tipo      NotificationType
  destino   String
  estado    String
  payload   Json?
  createdAt DateTime         @default(now())

  @@index([tenantId])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

model TwoFactorSession {
  id                 String    @id @default(cuid())
  userId             String
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  emailCode          String?
  emailCodeExpiresAt DateTime?
  emailCodeUsedAt    DateTime?
  expiresAt          DateTime
  usedAt             DateTime?
  createdAt          DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model BankProvisioningRequest {
  id              String             @id @default(cuid())
  bankId          String
  bank            Bank               @relation(fields: [bankId], references: [id])
  target          ProvisioningTarget
  status          ProvisioningStatus @default(REQUESTED)
  provider        String?
  domain          String?
  apiDomain       String?
  region          String?
  config          Json?
  credentials     Json?
  notes           String?
  createdByUserId String?
  processedAt     DateTime?
  errorMessage    String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([bankId])
  @@index([status])
  @@index([createdAt])
}

model AuditLog {
  id        String      @id @default(cuid())
  tenantId  String
  bank      Bank        @relation(fields: [tenantId], references: [id])
  userId    String?
  user      User?       @relation(fields: [userId], references: [id])
  action    AuditAction
  entity    String
  entityId  String
  before    Json?
  after     Json?
  createdAt DateTime    @default(now())

  @@index([tenantId])
  @@index([entity])
}
