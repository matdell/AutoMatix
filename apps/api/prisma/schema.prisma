generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPERADMIN
  BANK_ADMIN
  BANK_OPS
  BANK_APPROVER
  BANK_BRANCH_MANAGER
  BANK_BRANCH_OPERATOR
  BRAND_ADMIN
  LEGAL_ENTITY_ADMIN
  POS_ADMIN
  MERCHANT_ADMIN
  MERCHANT_USER
  ADMIN
  MERCHANT
  OPERATIONS
}

enum MerchantStatus {
  ACTIVE
  PENDING
  RESTRICTED
}

enum CardNetwork {
  VISA
  MASTERCARD
  AMEX
  CABAL
  NARANJA
  OTRA
}

enum CampaignType {
  DISCOUNT
  INSTALLMENTS
  CASHBACK
}

enum CampaignStatus {
  INVITED
  OPERATIONS
  PROCESSOR
  PARTIAL
  ACTIVE
  ARCHIVED
}

enum InvitationStatus {
  INVITED
  ACCEPTED
  REJECTED
  EXPIRED
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
}

enum NotificationType {
  INVITATION
  REMINDER
  VALIDATION_ERROR
  WELCOME
  PASSWORD_RESET
  TWO_FACTOR_CODE
}

model Bank {
  id             String   @id @default(cuid())
  nombre         String
  nombreCompleto String?
  razonSocial    String?
  cuit           String?
  direccionCasaMatriz String?
  slug           String   @unique
  logoUrl        String?
  paymentMethods String[]
  bines          String[]
  fechaAlta      DateTime?
  activo         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  users          User[]
  brands         Brand[]
  bankBranches   BankBranch[]
  merchants      Merchant[]
  branches       Branch[]
  categories     Category[]
  shoppings      Shopping[]
  branchEstablishments BranchEstablishment[]
  campaigns      Campaign[]
  invitations    Invitation[]
  validations    ValidationError[]
  notifications  Notification[]
  auditLogs      AuditLog[]
}

model BankBranch {
  id        String   @id @default(cuid())
  bankId    String
  bank      Bank     @relation(fields: [bankId], references: [id])
  nombre    String
  codigo    String?
  localidad String?
  region    String?
  tipo      String?
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users     User[]

  @@index([bankId])
}

model User {
  id            String   @id @default(cuid())
  tenantId      String
  bank          Bank     @relation(fields: [tenantId], references: [id])
  email         String
  passwordHash  String
  nombre        String
  role          Role
  brandId       String?
  merchantId    String?
  bankBranchId  String?
  pointOfSaleId String?
  isActive      Boolean  @default(true)
  twoFactorEmailEnabled Boolean @default(false)
  twoFactorTotpEnabled  Boolean @default(false)
  twoFactorTotpSecret   String?
  lastLoginAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  brand         Brand?     @relation(fields: [brandId], references: [id])
  merchant      Merchant? @relation(fields: [merchantId], references: [id])
  bankBranch    BankBranch? @relation(fields: [bankBranchId], references: [id])
  pointOfSale   Branch?    @relation("UserPointOfSale", fields: [pointOfSaleId], references: [id])
  auditLogs     AuditLog[]
  archivedCampaigns Campaign[] @relation("CampaignArchivedBy")
  passwordResetTokens PasswordResetToken[]
  twoFactorSessions TwoFactorSession[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([bankBranchId])
  @@index([brandId])
  @@index([merchantId])
  @@index([pointOfSaleId])
}

model Brand {
  id        String   @id @default(cuid())
  tenantId  String
  bank      Bank     @relation(fields: [tenantId], references: [id])
  nombre    String
  logoUrl   String?
  sitioWeb  String?
  facebook  String?
  instagram String?
  twitter   String?
  emailPrincipal String?
  telefonoPrincipal String?
  processor String?
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  legalEntities BrandLegalEntity[]
  categories   BrandCategory[]
  users        User[]

  @@index([tenantId])
}

model BrandLegalEntity {
  id         String   @id @default(cuid())
  tenantId   String
  brandId    String
  merchantId String
  createdAt  DateTime @default(now())

  brand      Brand    @relation(fields: [brandId], references: [id])
  merchant   Merchant @relation(fields: [merchantId], references: [id])

  @@unique([brandId, merchantId])
  @@index([tenantId])
  @@index([brandId])
  @@index([merchantId])
}

model Category {
  id        String   @id @default(cuid())
  tenantId  String
  bank      Bank     @relation(fields: [tenantId], references: [id])
  nombre    String
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  brands    BrandCategory[]

  @@unique([tenantId, nombre])
  @@index([tenantId])
}

model BrandCategory {
  id         String   @id @default(cuid())
  tenantId   String
  brandId    String
  categoryId String
  createdAt  DateTime @default(now())

  bank      Bank     @relation(fields: [tenantId], references: [id])
  brand     Brand    @relation(fields: [brandId], references: [id])
  category  Category @relation(fields: [categoryId], references: [id])

  @@unique([brandId, categoryId])
  @@index([tenantId])
  @@index([brandId])
  @@index([categoryId])
}

model Merchant {
  id            String         @id @default(cuid())
  tenantId      String
  bank          Bank           @relation(fields: [tenantId], references: [id])
  nombre        String
  razonSocial   String?
  categoria     String
  estado        MerchantStatus @default(PENDING)
  cuit          String?
  direccionSocial String?
  merchantNumber String?
  contactoEmail String?
  telefono      String?
  processor     String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  branches      Branch[]
  brands        BrandLegalEntity[]
  campaigns     CampaignMerchant[]
  invitations   Invitation[]
  validations   ValidationError[]
  users         User[]

  @@index([tenantId])
}

model Branch {
  id            String   @id @default(cuid())
  tenantId      String
  bank          Bank     @relation(fields: [tenantId], references: [id])
  merchantId    String
  merchant      Merchant @relation(fields: [merchantId], references: [id])
  nombre        String
  direccion     String
  calle         String?
  numero        String?
  piso          String?
  codigoPostal  String?
  ciudad        String
  provincia     String
  pais          String
  placeId       String?
  lat           Float?
  lng           Float?
  merchantNumber String?
  processor     String?
  shoppingId    String?
  shopping      Shopping? @relation(fields: [shoppingId], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  users         User[]   @relation("UserPointOfSale")
  establishments BranchEstablishment[]
  campaignLinks CampaignMerchant[]
  invitationLinks InvitationBranch[]

  @@index([tenantId])
  @@index([merchantId])
  @@index([shoppingId])
}

model Shopping {
  id        String   @id @default(cuid())
  tenantId  String
  bank      Bank     @relation(fields: [tenantId], references: [id])
  nombre    String
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  branches  Branch[]

  @@unique([tenantId, nombre])
  @@index([tenantId])
}

model BranchEstablishment {
  id          String      @id @default(cuid())
  tenantId    String
  bank        Bank        @relation(fields: [tenantId], references: [id])
  branchId    String
  branch      Branch      @relation(fields: [branchId], references: [id])
  cardNetwork CardNetwork
  number      String
  createdAt   DateTime    @default(now())

  @@unique([branchId, cardNetwork])
  @@index([tenantId])
  @@index([branchId])
}

model Campaign {
  id          String         @id @default(cuid())
  tenantId    String
  bank        Bank           @relation(fields: [tenantId], references: [id])
  nombre      String
  tipo        CampaignType
  estado      CampaignStatus @default(INVITED)
  estadoAnterior CampaignStatus?
  archivedAt  DateTime?
  archivedById String?
  archivedBy  User?          @relation("CampaignArchivedBy", fields: [archivedById], references: [id])
  fechaInicio DateTime
  fechaFin    DateTime
  condiciones Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  merchants   CampaignMerchant[]

  @@index([tenantId])
  @@index([archivedById])
}

model CampaignMerchant {
  id         String   @id @default(cuid())
  tenantId   String
  campaignId String
  merchantId String
  branchId   String?
  createdAt  DateTime @default(now())

  campaign   Campaign @relation(fields: [campaignId], references: [id])
  merchant   Merchant @relation(fields: [merchantId], references: [id])
  branch     Branch?  @relation(fields: [branchId], references: [id])

  @@index([tenantId])
  @@index([campaignId])
  @@index([merchantId])
}

model Invitation {
  id         String           @id @default(cuid())
  tenantId   String
  bank       Bank             @relation(fields: [tenantId], references: [id])
  email      String
  merchantId String?
  merchant   Merchant?        @relation(fields: [merchantId], references: [id])
  status     InvitationStatus @default(INVITED)
  token      String           @unique
  expiresAt  DateTime?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  branches   InvitationBranch[]

  @@index([tenantId])
}

model InvitationBranch {
  id           String     @id @default(cuid())
  tenantId     String
  invitationId String
  branchId     String

  invitation   Invitation @relation(fields: [invitationId], references: [id])
  branch       Branch     @relation(fields: [branchId], references: [id])

  @@index([tenantId])
}

model ValidationError {
  id         String   @id @default(cuid())
  tenantId   String
  bank       Bank     @relation(fields: [tenantId], references: [id])
  merchantId String
  merchant   Merchant @relation(fields: [merchantId], references: [id])
  codigo     String
  mensaje    String
  resuelto   Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([tenantId])
}

model Notification {
  id        String           @id @default(cuid())
  tenantId  String
  bank      Bank             @relation(fields: [tenantId], references: [id])
  tipo      NotificationType
  destino   String
  estado    String
  payload   Json?
  createdAt DateTime         @default(now())

  @@index([tenantId])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
}

model TwoFactorSession {
  id                 String   @id @default(cuid())
  userId             String
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  emailCode          String?
  emailCodeExpiresAt DateTime?
  emailCodeUsedAt    DateTime?
  expiresAt          DateTime
  usedAt             DateTime?
  createdAt          DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model AuditLog {
  id        String      @id @default(cuid())
  tenantId  String
  bank      Bank        @relation(fields: [tenantId], references: [id])
  userId    String?
  user      User?       @relation(fields: [userId], references: [id])
  action    AuditAction
  entity    String
  entityId  String
  before    Json?
  after     Json?
  createdAt DateTime    @default(now())

  @@index([tenantId])
  @@index([entity])
}
